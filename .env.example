# -----------------------------------------------------------------------------
# ECG Batch Platform – example environment variables
# Copy to .env and set values. Never commit .env.
# -----------------------------------------------------------------------------

# PostgreSQL (metadata store)
POSTGRES_USER=ecg
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ecg_metadata

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=ecg-datalake

# Ingestion (for docker compose run; set per run or for dev)
RUN_ID=2026-02-21_dev01
RUN_DATE=2026-02-21
INGEST_OVERWRITE=false
# RECORD_IDS=100,101,102
# RECORD_RANGE=100-124
# RECORD_LIMIT=5

# WFDB / data source (default synthetic mode)
WFDB_LOCAL_DIR=/data/mitdb
USE_SYNTHETIC_DATA=true
